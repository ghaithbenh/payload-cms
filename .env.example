PAYLOAD_SECRET=your-secret-key-here
DATABASE_URL=mongodb+srv://user:pass@cluster.mongodb.net/dbname

# Redis (Docker – see docker-compose.yml)
REDIS_HOST=REDIS_HOST
REDIS_PORT=REDIS_PORT

NEXT_PUBLIC_FRONTEND_URL=NEXT_PUBLIC_FRONTEND_URL

# CORS (comma-separated origins allowed, e.g. CORS_ORIGINS,https://example.com)
CORS_ORIGINS=CORS_ORIGINS

# Rate limiting: set to 'true' to allow requests when Redis is down (fail-open). Default is fail-closed.
RATE_LIMIT_FAIL_OPEN=false